{
  "server": {
    "host": "127.0.0.1",
    "port": 3000
  },
  "monitor": {
    "scriptPath": "../config/monitor.sh",
    "restartDelayMs": 2000,
    "movePairWindowMs": 750,
    "targets": [
      {
        "id": "sandbox",
        "rootPath": "../../tmp/watch",
        "enabled": true,
        "autoQuarantineEnabled": false,
        "demoAllowed": true
      }
    ]
  },
  "rules": [
    {
      "ruleId": "burst-create",
      "ruleName": "Bulk Create Burst",
      "eventType": "create",
      "threshold": 5,
      "windowMs": 10000,
      "incidentCooldownMs": 15000,
      "severity": "high",
      "autoQuarantine": false
    },
    {
      "ruleId": "burst-modify",
      "ruleName": "Bulk Modify Burst",
      "eventType": "modify",
      "threshold": 5,
      "windowMs": 10000,
      "incidentCooldownMs": 15000,
      "severity": "critical",
      "autoQuarantine": true
    },
    {
      "ruleId": "burst-delete",
      "ruleName": "Bulk Delete Burst",
      "eventType": "delete",
      "threshold": 5,
      "windowMs": 10000,
      "incidentCooldownMs": 15000,
      "severity": "high",
      "autoQuarantine": false
    }
  ]
}
